{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pet",
  "type": "object",
  "required": ["id", "name", "birthDate", "type"],
  "properties": {
    "id": { "type": "integer" },
    "name": { "type": "string" },
    "birthDate": { "type": "string" },
    "ownerId": { "type": "integer" },
    "type": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" }
      }
    },
    "visits": {
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
