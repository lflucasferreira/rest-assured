{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vet",
  "type": "object",
  "required": ["id", "firstName", "lastName"],
  "properties": {
    "id": { "type": "integer" },
    "firstName": { "type": "string" },
    "lastName": { "type": "string" },
    "specialties": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" }
        }
      }
    }
  }
}
